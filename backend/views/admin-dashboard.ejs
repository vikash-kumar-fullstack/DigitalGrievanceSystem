<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">
  <%- include("partials/header", { user: user }) %>
 <div class="main-content"> 
<div class="container">

  <div class="section">
    <h2>Create Department</h2>

    <form method="POST" action="/admin/create-department">
      <input type="text" name="name" placeholder="Department Name" required />
      <input type="email" name="email" placeholder="Department Email" required />
      <input type="password" name="password" placeholder="Temporary Password" required />

      <select name="level" required>
        <option value="">Select Level</option>
        <option value="1">Level 1</option>
        <option value="2">Level 2</option>
      </select>

      <input type="text" name="parentDepartment" placeholder="Higher Department (optional)" />

      <button style="padding: 10px;" type="submit">Create Department</button>
    </form>
  </div>

  <div class="section">
    <h2>Dashboard Analytics</h2>

    <div class="stats">
      <div class="stat-box">Total<br><%= totalComplaints %></div>
      <div class="stat-box">Pending<br><%= pending %></div>
      <div class="stat-box">In Progress<br><%= inProgress %></div>
      <div class="stat-box">Resolved<br><%= resolved %></div>
    </div>
  </div>

  <div class="section">
    <div class="chart-grid">

      <div class="chart-box">
        <h3>Status Distribution</h3>
        <canvas id="statusChart"></canvas>
      </div>

      <div class="chart-box">
        <h3>Department Complaints</h3>
        <canvas id="deptChart"></canvas>
      </div>

    </div>
  </div>

  <div class="section">
    <h2>Recent Complaints</h2>

    <% recentComplaints.forEach(c => { %>
      <div class="complaint-box">
        <p><strong>Status:</strong> <%= c.status %></p>
        <p><%= c.message %></p>
        <small><%= new Date(c.createdAt).toLocaleString() %></small>
      </div>
    <% }) %>
  </div>

</div>

<script id="chart-data" type="application/json">
  <%- JSON.stringify({
    pending,
    inProgress,
    resolved,
    complaintsByDept
  }) %>
</script>

<script>
const rawData = document.getElementById("chart-data").textContent;
const data = JSON.parse(rawData);

const deptLabels = data.complaintsByDept.map(d => d._id);
const deptCounts = data.complaintsByDept.map(d => d.count);

// STATUS
new Chart(document.getElementById("statusChart"), {
  type: "doughnut",
  data: {
    labels: ["Pending", "In Progress", "Resolved"],
    datasets: [{
      data: [data.pending, data.inProgress, data.resolved],
      backgroundColor: ["#ff6384", "#36a2eb", "#4caf50"]
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { position: "bottom" }
    }
  }
});

// DEPARTMENT
new Chart(document.getElementById("deptChart"), {
  type: "bar",
  data: {
    labels: deptLabels,
    datasets: [{
      data: deptCounts,
      backgroundColor: "#00c6ff",
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } }
  }
});
</script>
<script src="/socket.io/socket.io.js"></script>

<script>
  const socket = io();

  // join personal room
  socket.emit("join", "<%= user._id %>");

  socket.on("newNotification", (data) => {
    alert("🔔 " + data.message);

    // optional: reload page
    // location.reload();
  });
</script>
</div>
<%- include("partials/footer") %>
</body>
</html>