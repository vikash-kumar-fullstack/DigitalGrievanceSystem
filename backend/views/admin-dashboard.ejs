<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>

  <!-- Chart.js CDN -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    body {
      background: linear-gradient(135deg, #0f2027, #203a43);
      color: #fff;
      font-family: Segoe UI, sans-serif;
      padding: 40px;
    }

    .card {
  background: #203a43;
  padding: 30px;
  border-radius: 12px;
  max-width: 1200px; /* 🔥 increased */
  margin: auto;
}
.chart-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
    h2 {
      text-align: center;
      margin-bottom: 20px;
    }

    input, select {
      width: 100%;
      padding: 12px;
      margin-bottom: 15px;
      border-radius: 8px;
      border: none;
    }

    button {
      width: 100%;
      padding: 12px;
      background: #00c6ff;
      border: none;
      font-weight: bold;
      cursor: pointer;
    }

    .stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 30px;
}

.stat-box {
  background: linear-gradient(135deg, #2c5364, #203a43);
  padding: 20px;
  border-radius: 12px;
  text-align: center;
  font-size: 18px;
  font-weight: bold;
}
.stat-box:hover {
  transform: translateY(-5px);
  transition: 0.3s;
}
.chart-container {
  background: #ffffff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 30px;
  height: 300px; /* 🔥 CONTROL HEIGHT */
}

    h3 {
  margin-top: 40px;
  margin-bottom: 15px;
}
.complaint-box {
  border: 1px solid #ccc;
  padding: 15px;
  border-radius: 10px;
  margin-bottom: 15px;
  background: #2c5364;
}
.section {
  margin-top: 40px;
}
  </style>
</head>

<body>
  <div class="card">

    <!-- Create Department -->
    <h2>Create Department</h2>

    <form method="POST" action="/admin/create-department">
      <input type="text" name="name" placeholder="Department Name" required />
      <input type="email" name="email" placeholder="Department Email" required />
      <input type="password" name="password" placeholder="Temporary Password" required />

      <select name="level" required>
        <option value="">Select Level</option>
        <option value="1">Level 1 (Lower)</option>
        <option value="2">Level 2 (Higher)</option>
      </select>

      <input type="text" name="parentDepartment" placeholder="Higher Department (optional)" />

      <button type="submit">Create Department</button>
    </form>

    <!-- Analytics -->
    <h2>Dashboard Analytics</h2>

    <div class="stats">
      <div class="stat-box">Total<br><%= totalComplaints %></div>
      <div class="stat-box">Pending<br><%= pending %></div>
      <div class="stat-box">In Progress<br><%= inProgress %></div>
      <div class="stat-box">Resolved<br><%= resolved %></div>
    </div>

    <div class="chart-grid">

  <div class="chart-container">
    <h3>Status Distribution</h3>
    <canvas id="statusChart"></canvas>
  </div>

  <div class="chart-container">
    <h3>Complaints by Department</h3>
    <canvas id="deptChart"></canvas>
  </div>

</div>

    <!-- Recent Complaints -->
    <h3>Recent Complaints</h3>

    <% recentComplaints.forEach(c => { %>
      <div class="complaint-box" style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">
        <p><strong>Status:</strong> <%= c.status %></p>
        <p><%= c.message %></p>
        <small><%= new Date(c.createdAt).toLocaleString() %></small>
      </div>
    <% }) %>

  </div>
  <script id="chart-data" type="application/json">
  <%- JSON.stringify({
    pending,
    inProgress,
    resolved,
    complaintsByDept
  }) %>
</script>
  <!-- Charts Script -->
  <script>
  // ✅ Read data safely from DOM
  const rawData = document.getElementById("chart-data").textContent;
  const data = JSON.parse(rawData);

  const pending = data.pending;
  const inProgress = data.inProgress;
  const resolved = data.resolved;

  const deptLabels = data.complaintsByDept.map(d => d._id);
  const deptCounts = data.complaintsByDept.map(d => d.count);

  // 📊 STATUS CHART
new Chart(document.getElementById("statusChart"), {
  type: "doughnut", // 🔥 better than pie (professional look)
  data: {
    labels: ["Pending", "In Progress", "Resolved"],
    datasets: [{
      data: [pending, inProgress, resolved],
      backgroundColor: ["#ff6384", "#36a2eb", "#4caf50"],
      borderWidth: 1
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        position: "bottom"
      }
    }
  }
});

// 📊 DEPARTMENT CHART
new Chart(document.getElementById("deptChart"), {
  type: "bar",
  data: {
    labels: deptLabels,
    datasets: [{
      label: "Complaints",
      data: deptCounts,
      backgroundColor: "#00c6ff",
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        display: false
      }
    },
    scales: {
      y: {
        beginAtZero: true,
        ticks: {
          stepSize: 1
        }
      }
    }
  }
});
</script>

</body>
</html>