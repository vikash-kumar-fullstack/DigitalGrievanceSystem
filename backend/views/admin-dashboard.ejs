<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    body {
      margin: 0;
      background: linear-gradient(135deg, #0f2027, #203a43);
      font-family: 'Segoe UI', sans-serif;
      color: white;
    }

    .container {
      max-width: 1200px;
      margin: auto;
      padding: 30px 20px;
    }

    h2 {
      text-align: center;
      margin-bottom: 20px;
    }

    /* 🔥 SECTION CARD */
    .section {
      background: #203a43;
      padding: 25px;
      border-radius: 12px;
      margin-bottom: 30px;
    }

    /* 🔥 FORM */
    form input, form select {
      width: 100%;
      padding: 12px;
      margin-bottom: 12px;
      border-radius: 8px;
      border: none;
    }

    button {
      width: 100%;
      padding: 12px;
      background: #00c6ff;
      border: none;
      border-radius: 8px;
      font-weight: bold;
      cursor: pointer;
    }

    /* 🔥 STATS */
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
    }

    .stat-box {
      background: linear-gradient(135deg, #2c5364, #203a43);
      padding: 20px;
      border-radius: 10px;
      text-align: center;
      font-size: 18px;
      transition: 0.3s;
    }

    .stat-box:hover {
      transform: translateY(-5px);
    }

    /* 🔥 CHART GRID */
    .chart-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .chart-box {
      background: white;
      border-radius: 12px;
      padding: 15px;
      height: 320px;
      color: black;
    }

    .chart-box h3 {
      margin: 0 0 10px;
      text-align: center;
    }

    canvas {
      width: 100% !important;
      height: 250px !important;
    }

    /* 🔥 COMPLAINTS */
    .complaint-box {
      background: #2c5364;
      padding: 15px;
      border-radius: 10px;
      margin-bottom: 15px;
    }

    /* 🔥 RESPONSIVE */
    @media (max-width: 768px) {
      .chart-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

<div class="container">

  <!-- 🔥 CREATE DEPARTMENT -->
  <div class="section">
    <h2>Create Department</h2>

    <form method="POST" action="/admin/create-department">
      <input type="text" name="name" placeholder="Department Name" required />
      <input type="email" name="email" placeholder="Department Email" required />
      <input type="password" name="password" placeholder="Temporary Password" required />

      <select name="level" required>
        <option value="">Select Level</option>
        <option value="1">Level 1</option>
        <option value="2">Level 2</option>
      </select>

      <input type="text" name="parentDepartment" placeholder="Higher Department (optional)" />

      <button type="submit">Create Department</button>
    </form>
  </div>

  <!-- 🔥 ANALYTICS -->
  <div class="section">
    <h2>Dashboard Analytics</h2>

    <div class="stats">
      <div class="stat-box">Total<br><%= totalComplaints %></div>
      <div class="stat-box">Pending<br><%= pending %></div>
      <div class="stat-box">In Progress<br><%= inProgress %></div>
      <div class="stat-box">Resolved<br><%= resolved %></div>
    </div>
  </div>

  <!-- 🔥 CHARTS -->
  <div class="section">
    <div class="chart-grid">

      <div class="chart-box">
        <h3>Status Distribution</h3>
        <canvas id="statusChart"></canvas>
      </div>

      <div class="chart-box">
        <h3>Department Complaints</h3>
        <canvas id="deptChart"></canvas>
      </div>

    </div>
  </div>

  <!-- 🔥 RECENT -->
  <div class="section">
    <h2>Recent Complaints</h2>

    <% recentComplaints.forEach(c => { %>
      <div class="complaint-box">
        <p><strong>Status:</strong> <%= c.status %></p>
        <p><%= c.message %></p>
        <small><%= new Date(c.createdAt).toLocaleString() %></small>
      </div>
    <% }) %>
  </div>

</div>

<!-- 🔥 DATA -->
<script id="chart-data" type="application/json">
  <%- JSON.stringify({
    pending,
    inProgress,
    resolved,
    complaintsByDept
  }) %>
</script>

<!-- 🔥 CHART SCRIPT -->
<script>
const rawData = document.getElementById("chart-data").textContent;
const data = JSON.parse(rawData);

const deptLabels = data.complaintsByDept.map(d => d._id);
const deptCounts = data.complaintsByDept.map(d => d.count);

// STATUS
new Chart(document.getElementById("statusChart"), {
  type: "doughnut",
  data: {
    labels: ["Pending", "In Progress", "Resolved"],
    datasets: [{
      data: [data.pending, data.inProgress, data.resolved],
      backgroundColor: ["#ff6384", "#36a2eb", "#4caf50"]
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { position: "bottom" }
    }
  }
});

// DEPARTMENT
new Chart(document.getElementById("deptChart"), {
  type: "bar",
  data: {
    labels: deptLabels,
    datasets: [{
      data: deptCounts,
      backgroundColor: "#00c6ff",
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } }
  }
});
</script>
<script src="/socket.io/socket.io.js"></script>

<script>
  const socket = io();

  // join personal room
  socket.emit("join", "<%= user._id %>");

  socket.on("newNotification", (data) => {
    // 🔥 SIMPLE POPUP
    alert("🔔 " + data.message);

    // optional: reload page
    // location.reload();
  });
</script>
</body>
</html>